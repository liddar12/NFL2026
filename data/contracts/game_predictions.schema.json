{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "game_predictions.schema.json",
  "title": "Weekly game outcome predictions",
  "description": "Per-game win-probability vector for a week. Produced by scripts/models/game_model.py (full-vector blend), validated by scripts/validate_data.py.",
  "type": "object",
  "additionalProperties": false,
  "required": ["season", "week", "updated_utc", "games"],
  "properties": {
    "season": {
      "type": "integer",
      "minimum": 2026
    },
    "week": {
      "type": "integer",
      "description": "Regular-season week, 1..18.",
      "minimum": 1,
      "maximum": 18
    },
    "updated_utc": { "type": "string" },
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "game_id",
          "home",
          "away",
          "kickoff_utc",
          "roof",
          "probs",
          "model",
          "estimate"
        ],
        "properties": {
          "game_id": {
            "type": "string",
            "description": "Stable game identifier."
          },
          "home": {
            "type": "string",
            "enum": [
              "ARI", "ATL", "BAL", "BUF", "CAR", "CHI", "CIN", "CLE",
              "DAL", "DEN", "DET", "GB", "HOU", "IND", "JAX", "KC",
              "LV", "LAC", "LAR", "MIA", "MIN", "NE", "NO", "NYG",
              "NYJ", "PHI", "PIT", "SF", "SEA", "TB", "TEN", "WAS"
            ]
          },
          "away": {
            "type": "string",
            "enum": [
              "ARI", "ATL", "BAL", "BUF", "CAR", "CHI", "CIN", "CLE",
              "DAL", "DEN", "DET", "GB", "HOU", "IND", "JAX", "KC",
              "LV", "LAC", "LAR", "MIA", "MIN", "NE", "NO", "NYG",
              "NYJ", "PHI", "PIT", "SF", "SEA", "TB", "TEN", "WAS"
            ]
          },
          "kickoff_utc": {
            "type": "string",
            "description": "ISO-8601 UTC kickoff. Also the walk-forward information cutoff."
          },
          "roof": {
            "type": "string",
            "description": "Stadium roof state for weather gating.",
            "enum": ["indoor", "outdoor", "retractable"]
          },
          "probs": {
            "type": "object",
            "additionalProperties": false,
            "required": ["home", "away"],
            "description": "Win-probability vector; home + away should sum to ~1.",
            "properties": {
              "home": { "type": "number", "minimum": 0, "maximum": 1 },
              "away": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "model": {
            "type": "string",
            "description": "Which model produced this row (e.g. 'hybrid', 'elo', 'market')."
          },
          "estimate": {
            "type": "boolean",
            "description": "true => NOT a validated measurement (honesty flag)."
          }
        }
      }
    }
  }
}
