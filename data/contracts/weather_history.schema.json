{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "weather_history.schema.json",
  "title": "Kickoff-hour weather for open-roof home games (Open-Meteo archive)",
  "description": "Raw material for the weather_wind promotion family. Keyless archive data; open-roof venues only. A candidate earns pricing weight ONLY through NEVER-REGRESS.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_utc",
    "source",
    "games"
  ],
  "properties": {
    "generated_utc": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "games": {
      "type": "object",
      "minProperties": 500,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "wind_kph",
          "temp_c",
          "precip_mm"
        ],
        "properties": {
          "wind_kph": {
            "type": "number",
            "minimum": 0
          },
          "temp_c": {
            "type": "number"
          },
          "precip_mm": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}
